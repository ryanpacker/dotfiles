{{- /* Machine identity — default to current system values */ -}}
{{- $computerName := "" -}}
{{- if hasKey . "computerName" -}}
{{-   $computerName = .computerName -}}
{{- else -}}
{{-   $computerName = promptString "Computer name (friendly)" (output "scutil" "--get" "ComputerName" | trim) -}}
{{- end -}}

{{- $localHostName := "" -}}
{{- if hasKey . "localHostName" -}}
{{-   $localHostName = .localHostName -}}
{{- else -}}
{{-   $localHostName = promptString "Local hostname (no spaces)" (output "scutil" "--get" "LocalHostName" | trim) -}}
{{- end -}}

{{- $isWork := promptBoolOnce . "isWork" "Is this a work machine" -}}

{{- /* BambooHR is a sub-classification of a work machine. It's prompted
       separately because BHR's Jamf enforces things like hostname naming
       that we need to skip rather than fight, and deploys apps we need
       to skip in the Brewfile. */ -}}
{{- $isBHR := false -}}
{{- if $isWork -}}
{{-   $isBHR = promptBoolOnce . "isBHR" "Is this a BambooHR-managed machine" -}}
{{- end -}}

{{- /* User identity */ -}}
{{- $fullName := promptStringOnce . "fullName" "Full name (for git)" -}}
{{- $email := promptStringOnce . "email" "Email address (for git)" -}}

{{- /* NAS and Forgejo prompts run on all machines. Empty answers are fine —
       the gitconfig template and any NAS-touching scripts key off non-empty
       values, so leaving them blank just skips the relevant sections. */ -}}
{{- $nasIP := promptStringOnce . "nasIP" "NAS IP address (blank if none)" -}}
{{- $nasUser := "" -}}
{{- if hasKey . "nasUser" -}}
{{-   $nasUser = .nasUser -}}
{{- else -}}
{{-   $nasUser = promptString "NAS SSH username" .chezmoi.username -}}
{{- end -}}
{{- $forgejoDomain := promptStringOnce . "forgejoDomain" "Forgejo domain (blank if none, e.g. forge.example.com)" -}}

[data]
    computerName = {{ $computerName | quote }}
    localHostName = {{ $localHostName | quote }}
    isWork = {{ $isWork }}
    isBHR = {{ $isBHR }}
    fullName = {{ $fullName | quote }}
    email = {{ $email | quote }}
    nasIP = {{ $nasIP | quote }}
    nasUser = {{ $nasUser | quote }}
    forgejoDomain = {{ $forgejoDomain | quote }}
